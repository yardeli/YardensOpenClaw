# ClawFree Configuration

# Gateway
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0

# Supabase (optional — works without for local-only mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Claude — choose one mode:
# Mode 1: CLI (local, uses your subscription, zero cost)
CLAUDE_CLI_PATH=claude
# Mode 2: API (hosted, set your Anthropic API key)
# ANTHROPIC_API_KEY=sk-ant-...
# CLAUDE_MODEL=claude-sonnet-4-20250514
# CLAUDE_MODE=api

# Security
GATEWAY_SECRET=change-me-in-production

# Agent workspace
WORKSPACE_DIR=./workspace

# Memory
MEMORY_DIR=~/.clawfree/memory

# Channels (optional)
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
