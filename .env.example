# ClawFree Configuration
# Zero API cost — powered by Claude CLI and your Claude Pro/Max subscription.

# Gateway
GATEWAY_PORT=4000
GATEWAY_HOST=0.0.0.0

# Claude CLI (required)
# Install: npm install -g @anthropic-ai/claude-code
# Authenticate: claude --login
CLAUDE_CLI_PATH=claude
CLAUDE_TIMEOUT=120000
CLAUDE_MAX_CONCURRENT=3

# Security
GATEWAY_SECRET=change-me-in-production

# Agent workspace
WORKSPACE_DIR=./workspace

# Memory
MEMORY_DIR=~/.clawfree/memory

# Supabase (optional — works without for local-only mode)
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_KEY=

# Channels (optional)
TELEGRAM_BOT_TOKEN=
SLACK_BOT_TOKEN=
SLACK_SIGNING_SECRET=
DISCORD_BOT_TOKEN=
